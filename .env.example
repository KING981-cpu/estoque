DB_HOST=db
DB_PORT=3306
DB_NAME=estoque
DB_USER=estoque
DB_PASS=your_database_password_here

# SMTP configuration for outgoing email delivery
# Use the corporate SMTP server and the address provided by your service team.
SMTP_HOST=smtp.seu-servidor-corporativo.com
SMTP_PORT=465
SMTP_USER=avisos.estoque@olimpia.sp.gov.br
SMTP_PASS=sua_senha_ou_app_password
SMTP_FROM_EMAIL=avisos.estoque@olimpia.sp.gov.br
SMTP_SECURE=ssl

# MailHog local monitor copia as mensagens para visualização local
SMTP_MONITOR_HOST=mailhog
SMTP_MONITOR_PORT=1025
SMTP_MONITOR_FROM_EMAIL=alerta@estoque.local
SMTP_MONITOR_SECURE=

# Se sua rede ou servidor usar TLS em vez de SSL, ajuste para:
# SMTP_PORT=587
# SMTP_SECURE=tls
